# ============================================================
# Orthodox Catechesis — Apache configuration
# ============================================================

# ── HTTPS redirect ──────────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Remove trailing slash (except root) ────────────────────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# ── Deny direct HTTP access to sensitive directories ────────
RewriteRule ^(config|lang|activities|includes)(/|$) - [F,L]

# ── Block access to dot-files / dot-dirs ────────────────────
RewriteRule (^|/)\. - [F,L]

# ── Block access to JSON files directly ─────────────────────
<FilesMatch "\.json$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Block PHP files inside protected dirs ───────────────────
<FilesMatch "\.php$">
    Order allow,deny
    Allow from all
</FilesMatch>

# ── Security headers ────────────────────────────────────────
<IfModule mod_headers.c>
    # Prevent MIME sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Prevent clickjacking
    Header always set X-Frame-Options "DENY"

    # XSS Protection (legacy browsers)
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions policy
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # HSTS (1 year, include subdomains)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Content Security Policy
    # All JS/CSS assets are served locally. The @alpinejs/csp build avoids eval()
    # and new Function(), so 'unsafe-eval' is not needed. No CDN domains required.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"

    # Remove server information
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ── Disable directory listing ────────────────────────────────
Options -Indexes

# ── Disable server signature ────────────────────────────────
ServerSignature Off

# ── PHP settings (shared hosting) ───────────────────────────
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log /tmp/cateheza_errors.log
</IfModule>

# ── Compression ─────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>

# ── Cache control for assets ─────────────────────────────────
<FilesMatch "\.(css|js|png|jpg|jpeg|webp|gif|ico|svg)$">
    Header set Cache-Control "public, max-age=2592000"
</FilesMatch>
